# Dashi non-secret configuration (placeholders only).
#
# API keys are NEVER stored here or in any file — they live in the macOS Keychain.
# This file is only for non-secret runtime config and is safe to commit.

# Usage source: offline | anthropic | openai | aggregate  (default: offline)
DASHI_PROVIDER_MODE=offline

# How often to refresh usage, in seconds (default: 300)
DASHI_POLL_INTERVAL=300
