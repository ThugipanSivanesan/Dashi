# Swift / SwiftPM
.build/
.swiftpm/
# The Xcode project is generated from project.yml by XcodeGen — never commit it
*.xcodeproj/
*.xcworkspace/xcuserdata/
*.xcuserstate
DerivedData/
# Release artifacts produced by Scripts/make-dmg.sh
dist/

# Local security audit report — never commit
security-report.html

# Code-coverage profiles (from `swift test --enable-code-coverage`)
*.profraw
*.profdata

# Secrets — Dashi never writes secrets to disk (API keys it creates live in the macOS Keychain;
# subscription tokens are read read-only from the provider CLIs' own files). Keep stray secret files out.
.env
.env.*
!.env.example
*.key
*.pem
secrets/

# macOS
.DS_Store
